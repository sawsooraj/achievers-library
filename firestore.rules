rules_version = '2';

// =============================================================================
// Achievers Library — Firestore Security Rules  (PROJECT: library-32f31)
//
// PUBLISH:  Firebase Console -> Firestore Database -> Rules -> paste this -> Publish
//
// DO THIS FIRST (or the admin can't manage data):
//   1. Firebase Console -> Authentication -> Sign-in method -> enable Email/Password
//   2. Authentication -> Users -> Add user -> create your admin (email + password)
//   3. On the app's /admin/login, sign in with that EMAIL + PASSWORD and confirm the
//      dashboard + members load.
//   4. THEN publish these rules.
//
// After publishing:
//   - Anyone can still REGISTER (validated create) -> the public form keeps working.
//   - Reading member data and any update/delete now REQUIRE a signed-in admin, so a
//     random person can no longer read your students' details or wipe your records.
//   - Always log in with EMAIL + PASSWORD (password-only has no token and won't work).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    match /members/{memberId} {
      // Public registration: allowed, but only a sane, size-limited payload.
      allow create: if isValidNewMember(request.resource.data);
      // Everything else needs a signed-in admin (Firebase Auth).
      allow read, update, delete: if request.auth != null;
    }

    // Slot counts only (no personal data) — public form reads these to show
    // seat availability; only a signed-in admin can write them.
    match /stats/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isValidNewMember(d) {
  return d.size() <= 50
      && d.fullName is string && d.fullName.size() > 0 && d.fullName.size() <= 120
      && d.email is string && d.email.size() <= 200
      && d.phone is string && d.phone.size() <= 15
      && (!('amount' in d) || d.amount is number)
      // base64 UPI screenshots must stay under Firestore's 1 MiB doc limit
      && (!('upiScreenshot' in d) || d.upiScreenshot == null || d.upiScreenshot.size() < 900000);
}
